{
  "name": "sistema-de-usuarios-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm -w backend run dev",
    "dev:frontend": "npm -w frontend run dev",
    "dev:all": "node start-dev.js || start-dev.bat",
    "dev:all:win": "start-dev.bat",
    "seed": "npm -w backend run seed",
    "build": "npm -w frontend run build",
    "start": "npm -w backend run start",
    "studio": "npx prisma studio --schema backend/prisma/schema.prisma"
  },
  "overrides": {
    "vite": "4.5.14",
    "rollup": "^4.24.0"
  },
  "dependencies": {
    "@prisma/client": "^7.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "nodemailer": "^7.0.12"
  },
  "devDependencies": {
    "baseline-browser-mapping": "^2.9.16",
    "prisma": "^7.2.0"
  }
}