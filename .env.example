# Ejemplo de Variables de Entorno
# Copiar este archivo a .env y configurar los valores

# ===== ENTORNO =====
NODE_ENV=production

# ===== SERVIDOR =====
PORT=3005

# ===== BASE DE DATOS =====
# SQLite (por defecto)
DATABASE_URL="file:./backend/prisma/rotator.db"

# MySQL (alternativa)
# DATABASE_URL="mysql://user:password@localhost:3306/rotator_db"

# PostgreSQL (alternativa)
# DATABASE_URL="postgresql://user:password@localhost:5432/rotator_db"

# ===== JWT SECRETS =====
# IMPORTANTE: Generar secrets únicos para producción
# Usar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret-key-in-production
JWT_REFRESH_SECRET=change-this-to-another-random-secret-key-in-production

# ===== CORS =====
# URL del frontend para configurar CORS
FRONTEND_ORIGIN=http://localhost:5180

# ===== EMAIL (para recuperación de contraseña) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ===== PAYPAL (opcional) =====
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox

# ===== SWAGGER =====
# Habilitar Swagger UI en producción (no recomendado)
ENABLE_SWAGGER=false

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
